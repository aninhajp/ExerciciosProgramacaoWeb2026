<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Agendamento Confirmado</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">

  <div class="container py-5">
    <div class="card shadow-sm">

      <div class="card-header bg-success text-white text-center py-3">
        <h2 class="mb-0">✅ Agendamento Confirmado!</h2>
      </div>

      <div class="card-body p-4">

        <h5 class="text-primary border-bottom pb-2 mb-3">Dados do Paciente</h5>

        <p><strong>Nome:</strong> <%= agendamento.nome %> <%= agendamento.sobrenome %></p>
        <p><strong>CPF:</strong> <%= agendamento.cpf %></p>
        <p><strong>Data de Nascimento:</strong>
          <%
            var p = agendamento.nascimento.split('-');
            var nascFormatado = p[2] + '/' + p[1] + '/' + p[0];
          %>
          <%= nascFormatado %>
        </p>
        <p><strong>Telefone:</strong> <%= agendamento.telefone %></p>
        <p><strong>CEP:</strong> <%= agendamento.cep %></p>
        <p><strong>Endereço:</strong> <%= agendamento.endereco %></p>

          <h5 class="text-primary border-bottom pb-2 mb-3 mt-4">Dados da Consulta</h5>

        <p><strong>Clínica:</strong> <%= agendamento.clinica %></p>
        <p><strong>Especialidade:</strong> <%= agendamento.especialidade %></p>
        <p><strong>Data:</strong>
          <%
            var d = agendamento.data.split('-');
            var dataFormatada = d[2] + '/' + d[1] + '/' + d[0];
          %>
          <%= dataFormatada %>
        </p>
        <p><strong>Hora:</strong> <%= agendamento.hora %></p>

        <% if (agendamento.observacao && agendamento.observacao.trim() !== '') { %>
          <p><strong>Observação:</strong> <%= agendamento.observacao %></p>
        <% } %>

        <a href="/" class="btn btn-primary mt-3">← Novo Agendamento</a>

      </div>
    </div>
  </div>

</body>
</html>
