<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Agendamento de Consulta</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">

  <div class="container py-5">
    <div class="card shadow-sm">

      <div class="card-header bg-primary text-white text-center py-3">
        <h2 class="mb-0">Agendamento de Consulta</h2>
      </div>

      <div class="card-body p-4">

        <% if (erros.length > 0) { %>
          <div class="alert alert-danger">
            <strong>Antes de continuar é necessário preencher esses campos: </strong>
            <ul class="mb-0 mt-2">
              <% erros.forEach(function(e) { %>
                <li><%= e.mensagem %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>

        <form action="/" method="POST">

          <h5 class="text-primary border-bottom pb-2 mb-3">Dados do Paciente</h5>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="nome" class="form-label">Nome</label>
              <input type="text" id="nome" name="nome"
                     class="form-control <%= erros.find(e => e.campo === 'nome') ? 'is-invalid' : '' %>"
                     value="<%= dados.nome || '' %>" placeholder="Seu nome" />
              <% const erroNome = erros.find(e => e.campo === 'nome'); %>
              <% if (erroNome) { %><div class="invalid-feedback"><%= erroNome.mensagem %></div><% } %>
            </div>
            <div class="col-md-6 mb-3">
              <label for="sobrenome" class="form-label">Sobrenome</label>
              <input type="text" id="sobrenome" name="sobrenome"
                     class="form-control <%= erros.find(e => e.campo === 'sobrenome') ? 'is-invalid' : '' %>"
                     value="<%= dados.sobrenome || '' %>" placeholder="Seu sobrenome" />
              <% const erroSobrenome = erros.find(e => e.campo === 'sobrenome'); %>
              <% if (erroSobrenome) { %><div class="invalid-feedback"><%= erroSobrenome.mensagem %></div><% } %>
            </div>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="cpf" class="form-label">CPF</label>
              <input type="text" id="cpf" name="cpf"
                     class="form-control <%= erros.find(e => e.campo === 'cpf') ? 'is-invalid' : '' %>"
                     value="<%= dados.cpf || '' %>" placeholder="000.000.000-00" maxlength="14" />
              <% const erroCpf = erros.find(e => e.campo === 'cpf'); %>
              <% if (erroCpf) { %><div class="invalid-feedback"><%= erroCpf.mensagem %></div><% } %>
            </div>
            <div class="col-md-6 mb-3">
              <label for="nascimento" class="form-label">Data de Nascimento</label>
              <input type="date" id="nascimento" name="nascimento"
                     class="form-control <%= erros.find(e => e.campo === 'nascimento') ? 'is-invalid' : '' %>"
                     value="<%= dados.nascimento || '' %>" />
              <% const erroNasc = erros.find(e => e.campo === 'nascimento'); %>
              <% if (erroNasc) { %><div class="invalid-feedback"><%= erroNasc.mensagem %></div><% } %>
            </div>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="telefone" class="form-label">Telefone</label>
              <input type="text" id="telefone" name="telefone"
                     class="form-control <%= erros.find(e => e.campo === 'telefone') ? 'is-invalid' : '' %>"
                     value="<%= dados.telefone || '' %>" placeholder="(00) 00000-0000" maxlength="15" />
              <% const erroTel = erros.find(e => e.campo === 'telefone'); %>
              <% if (erroTel) { %><div class="invalid-feedback"><%= erroTel.mensagem %></div><% } %>
            </div>
            <div class="col-md-6 mb-3">
              <label for="cep" class="form-label">CEP</label>
              <input type="text" id="cep" name="cep"
                     class="form-control <%= erros.find(e => e.campo === 'cep') ? 'is-invalid' : '' %>"
                     value="<%= dados.cep || '' %>" placeholder="00000-000" maxlength="9" />
              <% const erroCep = erros.find(e => e.campo === 'cep'); %>
              <% if (erroCep) { %><div class="invalid-feedback"><%= erroCep.mensagem %></div><% } %>
            </div>
          </div>

          <div class="mb-4">
            <label for="endereco" class="form-label">Endereço</label>
            <input type="text" id="endereco" name="endereco"
                   class="form-control <%= erros.find(e => e.campo === 'endereco') ? 'is-invalid' : '' %>"
                   value="<%= dados.endereco || '' %>" placeholder="Rua, número, bairro, cidade" />
            <% const erroEnd = erros.find(e => e.campo === 'endereco'); %>
            <% if (erroEnd) { %><div class="invalid-feedback"><%= erroEnd.mensagem %></div><% } %>
          </div>

          <h5 class="text-primary border-bottom pb-2 mb-3">Dados da Consulta</h5>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="clinica" class="form-label">Clínica</label>
              <select id="clinica" name="clinica"
                      class="form-select <%= erros.find(e => e.campo === 'clinica') ? 'is-invalid' : '' %>">
                <option value="">Selecione uma clínica</option>
                <option value="Clínica Central" <%= dados.clinica === 'Clínica Central' ? 'selected' : '' %>>Clínica Central</option>
                <option value="Clínica Norte"   <%= dados.clinica === 'Clínica Norte'   ? 'selected' : '' %>>Clínica Norte</option>
                <option value="Clínica Sul"     <%= dados.clinica === 'Clínica Sul'     ? 'selected' : '' %>>Clínica Sul</option>
                <option value="Clínica Leste"   <%= dados.clinica === 'Clínica Leste'   ? 'selected' : '' %>>Clínica Leste</option>
                <option value="Clínica Oeste"   <%= dados.clinica === 'Clínica Oeste'   ? 'selected' : '' %>>Clínica Oeste</option>
              </select>
              <% const erroClinica = erros.find(e => e.campo === 'clinica'); %>
              <% if (erroClinica) { %><div class="invalid-feedback"><%= erroClinica.mensagem %></div><% } %>
            </div>
            <div class="col-md-6 mb-3">
              <label for="especialidade" class="form-label">Especialidade</label>
              <select id="especialidade" name="especialidade"
                      class="form-select <%= erros.find(e => e.campo === 'especialidade') ? 'is-invalid' : '' %>">
                <option value="">Selecione uma especialidade</option>
                <option value="Clínico Geral" <%= dados.especialidade === 'Clínico Geral' ? 'selected' : '' %>>Clínico Geral</option>
                <option value="Cardiologia"   <%= dados.especialidade === 'Cardiologia'   ? 'selected' : '' %>>Cardiologia</option>
                <option value="Dermatologia"  <%= dados.especialidade === 'Dermatologia'  ? 'selected' : '' %>>Dermatologia</option>
                <option value="Ortopedia"     <%= dados.especialidade === 'Ortopedia'     ? 'selected' : '' %>>Ortopedia</option>
                <option value="Pediatria"     <%= dados.especialidade === 'Pediatria'     ? 'selected' : '' %>>Pediatria</option>
                <option value="Ginecologia"   <%= dados.especialidade === 'Ginecologia'   ? 'selected' : '' %>>Ginecologia</option>
                <option value="Neurologia"    <%= dados.especialidade === 'Neurologia'    ? 'selected' : '' %>>Neurologia</option>
                <option value="Oftalmologia"  <%= dados.especialidade === 'Oftalmologia'  ? 'selected' : '' %>>Oftalmologia</option>
              </select>
              <% const erroEsp = erros.find(e => e.campo === 'especialidade'); %>
              <% if (erroEsp) { %><div class="invalid-feedback"><%= erroEsp.mensagem %></div><% } %>
            </div>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="data" class="form-label">Data do Agendamento</label>
              <input type="date" id="data" name="data"
                     class="form-control <%= erros.find(e => e.campo === 'data') ? 'is-invalid' : '' %>"
                     value="<%= dados.data || '' %>" />
              <% const erroData = erros.find(e => e.campo === 'data'); %>
              <% if (erroData) { %><div class="invalid-feedback"><%= erroData.mensagem %></div><% } %>
            </div>
            <div class="col-md-6 mb-3">
              <label for="hora" class="form-label">Hora do Agendamento</label>
              <input type="time" id="hora" name="hora"
                     class="form-control <%= erros.find(e => e.campo === 'hora') ? 'is-invalid' : '' %>"
                     value="<%= dados.hora || '' %>" />
              <% const erroHora = erros.find(e => e.campo === 'hora'); %>
              <% if (erroHora) { %><div class="invalid-feedback"><%= erroHora.mensagem %></div><% } %>
            </div>
          </div>

          <div class="mb-4">
            <label for="observacao" class="form-label">Observação <span class="text-muted">(opcional)</span></label>
            <textarea id="observacao" name="observacao" class="form-control" rows="3"
                      placeholder="Escreva aqui alguma observação..."><%= dados.observacao || '' %></textarea>
          </div>

          <button type="submit" class="btn   btn-primary w-100">Enviar</button>

        </form>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('cpf').addEventListener('input', function() {
      var v = this.value.replace(/\D/g, '');
      v = v.replace(/(\d{3})(\d)/, '$1.$2');
      v = v.replace(/(\d{3})(\d)/, '$1.$2');
      v = v.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
      this.value = v;
    });
    document.getElementById('telefone').addEventListener('input', function() {
      var v = this.value.replace(/\D/g, '');
      v = v.replace(/^(\d{2})(\d)/, '($1) $2');
      v = v.replace(/(\d{5})(\d)/, '$1-$2');
      this.value = v;
    });
    document.getElementById('cep').addEventListener('input', function() {
      var v = this.value.replace(/\D/g, '');
      v = v.replace(/(\d{5})(\d)/, '$1-$2');
      this.value = v;
    });
  </script>

</body>
</html>
